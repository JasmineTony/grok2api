  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": "./.cache/tsconfig.node.tsbuildinfo",
    "noEmit": true,
    "strict": true
  },
  "include": ["vite.config.ts", "playwright.config.ts"]
}
